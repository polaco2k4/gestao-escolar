{
  "permissions": {
    "allow": [
      "Bash(npm run *)",
      "Bash(netstat -ano)",
      "Bash(findstr \":5000\")",
      "Bash(findstr \"LISTENING\")",
      "Bash(taskkill /PID 6504 /F)",
      "PowerShell(Stop-Process -Id 6504 -Force)",
      "Bash(curl -s -o /dev/null -w \"%{http_code}\" http://localhost:3000/health)",
      "Bash(curl -s http://localhost:3000/health)",
      "Bash(curl -s http://localhost:5000/health)",
      "Bash(npm install *)"
    ]
  }
}
